From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: lib-rocksdb-test <noreply@unikraft.org>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] adapt examples as callable functions

Rename main() to <name>_main(), make global path variables static,
replace assert() with TEST_ASSERT() that returns 1 on failure,
and replace system() shell call with DestroyDB() API.
---
--- a/examples/simple_example.cc
+++ b/examples/simple_example.cc
@@ -11,6 +11,12 @@
 #include "rocksdb/options.h"
 #include "rocksdb/slice.h"
 
+#define TEST_ASSERT(cond) \
+    do { if (!(cond)) { \
+        fprintf(stderr, "FAIL %s:%d: " #cond "\n", __FILE__, __LINE__); \
+        return 1; \
+    } } while (0)
+
 using ROCKSDB_NAMESPACE::DB;
 using ROCKSDB_NAMESPACE::Options;
 using ROCKSDB_NAMESPACE::PinnableSlice;
@@ -20,12 +26,12 @@
 using ROCKSDB_NAMESPACE::WriteOptions;
 
 #if defined(OS_WIN)
-std::string kDBPath = "C:\\Windows\\TEMP\\rocksdb_simple_example";
+static std::string kDBPath = "C:\\Windows\\TEMP\\rocksdb_simple_example";
 #else
-std::string kDBPath = "/tmp/rocksdb_simple_example";
+static std::string kDBPath = "/tmp/rocksdb_simple_example";
 #endif
 
-int main() {
+int simple_example_main(int argc, char** argv) {
   std::unique_ptr<DB> db;
   Options options;
   // Optimize RocksDB. This is the easiest way to get RocksDB to perform well
@@ -36,16 +42,16 @@
 
   // open DB
   Status s = DB::Open(options, kDBPath, &db);
-  assert(s.ok());
+  TEST_ASSERT(s.ok());
 
   // Put key-value
   s = db->Put(WriteOptions(), "key1", "value");
-  assert(s.ok());
+  TEST_ASSERT(s.ok());
   std::string value;
   // get value
   s = db->Get(ReadOptions(), "key1", &value);
-  assert(s.ok());
-  assert(value == "value");
+  TEST_ASSERT(s.ok());
+  TEST_ASSERT(value == "value");
 
   // atomically apply a set of updates
   {
@@ -56,15 +62,15 @@
   }
 
   s = db->Get(ReadOptions(), "key1", &value);
-  assert(s.IsNotFound());
+  TEST_ASSERT(s.IsNotFound());
 
   db->Get(ReadOptions(), "key2", &value);
